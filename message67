local function FormatRow(label, value)
    local pad = string.rep(" ", math.max(1, 12 - #label));
    return label .. pad .. tostring(value);
end;

local function GetResolverPhase()
    -- Find the most common phase across all tracked players
    local phases = { collecting = 0, testing = 0, optimized = 0 };
    local best_conf = 0;
    for _, rd in pairs(DB) do
        phases[rd.rPhase] = (phases[rd.rPhase] or 0) + 1;
        if rd.rConfidence > best_conf then best_conf = rd.rConfidence; end;
    end;
    if phases.optimized > 0 then
        return "optimized " .. best_conf .. "%";
    elseif phases.testing > 0 then
        return "testing";
    else
        return "collecting";
    end;
end;

