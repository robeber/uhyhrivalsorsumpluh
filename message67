        rLastAccCheck    = 0,
        rConfidence      = 0,
        rOptimalPred     = 0.145,  -- prediction time (seconds)
        resolvedPos      = nil,

        -- Anti-bait resolver
        abMethod         = ABMethod.PreVoid,
