local function Fmt(lbl,val)
    return lbl..string.rep(" ",math.max(1,10-#lbl))..tostring(val);
end;

local function GetPhase()
    local best,phase=0,"collecting";
    for _,rd in pairs(DB) do
        if rd.rPhase=="optimized" and rd.rConfidence>best then
            best=rd.rConfidence; phase="opt "..rd.rConfidence.."%";
        elseif rd.rPhase=="testing" and phase=="collecting" then
            phase="testing";
        end;
    end;
    return phase;
end;

