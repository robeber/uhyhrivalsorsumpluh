-- FPS
local _ff,_fl,_fv=0,tick(),0;
RunService.Heartbeat:Connect(function()
    _ff=_ff+1;
    local n=tick();
    if n-_fl>=0.5 then _fv=math.floor(_ff/(n-_fl)); _ff=0; _fl=n; end;
end);

local function Fmt(lbl,val)
    return lbl..string.rep(" ",math.max(1,11-#lbl))..tostring(val);
end;

local function GetPhase()
    local best,phase=0,"collecting";
    for _,rd in pairs(DB) do
        if rd.rPhase=="optimized" and rd.rConfidence>best then
            best=rd.rConfidence; phase="opt "..rd.rConfidence.."%";
        elseif rd.rPhase=="testing" and phase=="collecting" then
            phase="testing";
        end;
    end;
    return phase;
end;

task.spawn(function()
    while TR_SG.Parent do
        task.wait(0.15);
        local kd = TRACKER.Deaths>0
            and string.format("%.2f",TRACKER.Kills/TRACKER.Deaths)
            or tostring(TRACKER.Kills);
        local hr = TRACKER.Shots>0
            and math.floor(TRACKER.Hits/TRACKER.Shots*100).."%"
            or "0%";
        local upt=math.floor(tick()-TRACKER.StartTime);
        local us=upt<60 and upt.."s" or math.floor(upt/60).."m "..upt%60 .."s";

        TrRows["kills"].Text    = Fmt("Kills",    TRACKER.Kills);
        TrRows["deaths"].Text   = Fmt("Deaths",   TRACKER.Deaths);
        TrRows["kd"].Text       = Fmt("K/D",      kd);
        TrRows["hitrate"].Text  = Fmt("Hit Rate", hr);
        TrRows["shots"].Text    = Fmt("Shots",    TRACKER.Shots);
        TrRows["resolver"].Text = Fmt("Resolver", GetPhase());
        TrRows["void"].Text     = Fmt("Void",     VOID_CFG.Enabled and "ON" or "off");
        TrRows["sling"].Text    = Fmt("Sling",    HoldingSlingshot and "ACTIVE" or "off");
        TrRows["slingop"].Text  = Fmt("Sling OP", SlingshotOP and "ON" or "off");
        TrRows["burst"].Text    = Fmt("Pkt Burst",PacketBurst and "ON" or "off");
        TrRows["ld"].Text       = Fmt("Low Detail",LowDetailActive and "ON" or "off");
        TrRows["fps"].Text      = Fmt("FPS",      _fv);
        TrRows["uptime"].Text   = Fmt("Uptime",   us);

        local kdn=tonumber(kd) or 0;
        TrRows["kd"].TextColor3    = kdn>=2 and RGB(55,205,95) or kdn>=1 and RGB(205,185,55) or RGB(205,65,65);
        TrRows["fps"].TextColor3   = _fv>=55 and RGB(55,205,95) or _fv>=30 and RGB(205,185,55) or RGB(205,65,65);
        TrRows["void"].TextColor3  = VOID_CFG.Enabled and RGB(55,205,95) or RGB(95,95,115);
        TrRows["sling"].TextColor3 = HoldingSlingshot and RGB(70,148,255) or RGB(95,95,115);
        TrRows["slingop"].TextColor3 = SlingshotOP and RGB(245,145,45) or RGB(95,95,115);
        TrRows["burst"].TextColor3   = PacketBurst and RGB(195,65,205) or RGB(95,95,115);
    end;
end);

-- Wrap OnHit/OnMiss with tracker counts
local _roh=OnHit; local _rom=OnMiss;
OnHit=function(p) TRACKER.Hits=TRACKER.Hits+1; TRACKER.Shots=TRACKER.Shots+1; _roh(p); end;
OnMiss=function(p) TRACKER.Shots=TRACKER.Shots+1; _rom(p); end;

-- Update globals
if getgenv then
    local ue=getgenv().UERage or {};
    ue.OnHit             = OnHit;
    ue.OnMiss            = OnMiss;
    ue.LowDetailToggle   = function() if LowDetailActive then RemoveLowDetail(); else ApplyLowDetail(); end; return LowDetailActive; end;
    ue.SlingshotOPToggle = function() SlingshotOP=not SlingshotOP; return SlingshotOP; end;
    ue.PacketBurstToggle = function() PacketBurst=not PacketBurst; return PacketBurst; end;
    ue.Tracker           = TRACKER;
    getgenv().UERage     = ue;
end;

