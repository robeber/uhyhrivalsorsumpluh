-- Learning phases (from Horizon)
local Phase = { Collecting = "collecting", Testing = "testing", Optimized = "optimized" };

-- Standard resolver methods (from Horizon)
local RMethod = { Velocity = "velocity", History = "history", BodyPart = "bodypart", Hybrid = "hybrid" };
local RMethodList = { RMethod.Velocity, RMethod.History, RMethod.BodyPart, RMethod.Hybrid };

-- Anti-bait methods (from Horizon)
local ABMethod = { PreVoid = "prevoid", VelExtrap = "velextrap", AltBody = "altbody", NetPos = "netpos", RevPred = "revpred", Hybrid = "hybrid" };
local ABMethodList = { ABMethod.PreVoid, ABMethod.VelExtrap, ABMethod.AltBody, ABMethod.NetPos, ABMethod.RevPred, ABMethod.Hybrid };

-- Yaw candidates (ours)
local YAW_CANDIDATES = { 0, 180, 58, -58, 90, -90, 135, -135, 27, -27 };

-- Void resolve modes (ours)
local VOID_MODES = { "Extrapolate", "Average", "Last" };

local function NewYawScores()
    local t = {};
    for _, y in YAW_CANDIDATES do t[y] = 1.0; end;
    return t;
end

local function NewVoidScores()
    local t = {};
    for _, m in VOID_MODES do t[m] = 1.0; end;
    return t;
end

local function NewMethodAccuracy(list)
    local t = {};
    for _, m in list do t[m] = 0; end;
    return t;
end

