-- ─────────────────────────────────────────────────────────────────
--  SLINGSHOT OPTIMIZATIONS
--
--  Slingshot-specific tuning applied on top of the base resolver:
--
--  1. Prediction time tuned to slingshot projectile speed (~180 su/s)
--     At 200ms ping: flight_time = dist/180 + 0.200 latency
--     We cache this per-enemy and update it each frame based on
--     their current distance to LocalPlayer.
--
--  2. Firerate patch: slingshot has an inherent delay between shots.
--     We zero FireRate and ReloadLength aggressively.
--
--  3. Resolver bias: slingshot shots are slow projectiles so
--     Velocity method is almost always better than History.
--     We boost Velocity method score by default for all enemies
--     when slingshot is held.
--
--  4. Spread is already zeroed by NoSpread, but we also hook
--     the projectile module specifically for slingshot to ensure
--     the actual projectile launch direction is never randomized.
-- ─────────────────────────────────────────────────────────────────

local SLING_SPEED   = 180;  -- studs/sec (slingshot projectile)
local SLING_GRAVITY = 196.2; -- Roblox gravity (workspace.Gravity default)

-- Cache workspace gravity in case server changed it
pcall(function() SLING_GRAVITY = workspace.Gravity; end);

-- Track whether local player is holding slingshot
local HoldingSlingshot = false;

local function CheckWeapon()
    local char = GetChar();
    if not char then HoldingSlingshot = false; return; end;
    local tool = char:FindFirstChildOfClass("Tool");
    HoldingSlingshot = tool and tool.Name:lower():find("slingshot") ~= nil or false;
end;

RunService.Heartbeat:Connect(CheckWeapon);

-- Per-enemy slingshot prediction (accounts for distance + ping + gravity drop)
local PING_ESTIMATE = 0.200; -- 200ms baseline for Singapore servers
-- Try to read actual ping from Stats
pcall(function()
    local stats = game:GetService("Stats");
    local net   = stats:FindFirstChild("Network");
    local ping  = net and net:FindFirstChild("ServerStatsItem") -- varies by executor
    -- Fallback: keep 0.200
end);

local function GetSlingshotPred(player)
    if not HoldingSlingshot then return nil; end;
    local myRoot = GetRoot();
    local thRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart");
    if not myRoot or not thRoot then return nil; end;

    local dist     = (myRoot.Position - thRoot.Position).Magnitude;
    local tof      = dist / SLING_SPEED;           -- time of flight
    local totalLag = tof + PING_ESTIMATE;           -- total lag to account for

    -- Gravity drop Y component: 0.5 * g * tof^2 (we aim higher to compensate)
    local gravDrop = 0.5 * SLING_GRAVITY * (tof * tof);

    return totalLag, gravDrop;
end;

-- Override rOptimalPred per-enemy every frame when holding slingshot
RunService.Heartbeat:Connect(function()
    if not HoldingSlingshot then return; end;
    for player, rd in pairs(DB) do
        if not IsAlive(player) then continue; end;
        local pred, drop = GetSlingshotPred(player);
        if pred then
            rd.rOptimalPred = pred;
            rd.gravDrop     = drop or 0;
            -- Bias resolver toward Velocity when we're holding slingshot
            -- (slow projectile = velocity prediction is almost always best)
            if rd.rMethodAcc[RMethod.Velocity] then
                rd.rMethodAcc[RMethod.Velocity] = math.min(100,
                    rd.rMethodAcc[RMethod.Velocity] + 0.5);
            end;
        end;
    end;
end);

-- ── Slingshot base patch + OP mode ──────────────────────────────
local SlingshotOP = false; -- toggled from GUI (off by default)

task.spawn(function()
    local mods = ReplicatedStorage:WaitForChild("Modules", 10);
    if not mods then return; end;
    local ok, IL = pcall(require, mods:WaitForChild("ItemLibrary", 10));
    if not ok or not IL then return; end;
    local Items = rawget(IL, "Items");
    if not Items then return; end;

    local function PatchSlingshot()
        for _, Item in Items do
            if not Item.Name:lower():find("slingshot") then continue; end;
            for _, field in {
                "ReloadLength","FireRate","Spread","Bloom",
                "Recoil","RecoveryTime","ChargeTime","WindupTime",
                "AimDownSightsTime","AimOutTime","EquipTime",
            } do
                if rawget(Item, field) ~= nil then rawset(Item, field, 0); end;
            end;
            if rawget(Item, "ProjectileSpeed") then
                rawset(Item, "ProjectileSpeed", SlingshotOP and 99999 or 9999);
            end;
            if SlingshotOP then
                for _, field in {"Damage","HeadshotMultiplier","MinDamage"} do
                    if rawget(Item, field) ~= nil then rawset(Item, field, 9999); end;
                end;
                for _, field in {"MaxDistance","Range"} do
                    if rawget(Item, field) ~= nil then rawset(Item, field, 99999); end;
                end;
                if rawget(Item, "PierceCount")  then rawset(Item, "PierceCount",  999); end;
                if rawget(Item, "FalloffStart") then rawset(Item, "FalloffStart", 0);   end;
                if rawget(Item, "FalloffEnd")   then rawset(Item, "FalloffEnd",   0);   end;
                if rawget(Item, "FireMode")     then rawset(Item, "FireMode", "auto");  end;
            end;
        end;
    end;

    PatchSlingshot();
    while task.wait(3) do PatchSlingshot(); end;
end);

-- ─────────────────────────────────────────────────────────────────
--  LOW DETAIL MODE
--
--  Strips as much visual noise as possible to squeeze FPS on
--  mobile / low-end devices. Off by default.
--  Affects: textures, meshes, particles, decals, post-processing,
--           shadows, terrain quality, water rendering, sounds.
-- ─────────────────────────────────────────────────────────────────

local LowDetailActive = false;
local LowDetailBackup = {}; -- store originals for restore

local function ApplyLowDetail()
    if LowDetailActive then return; end;
    LowDetailActive = true;

    -- Lighting: remove Sky, Atmosphere, all PostEffects, zero shadows
    pcall(function()
        local L = game:GetService("Lighting");
        LowDetailBackup.GlobalShadows            = L.GlobalShadows;
        LowDetailBackup.Brightness               = L.Brightness;
        LowDetailBackup.FogEnd                   = L.FogEnd;
        LowDetailBackup.FogStart                 = L.FogStart;
        LowDetailBackup.EnvironmentDiffuseScale  = L.EnvironmentDiffuseScale;
        LowDetailBackup.EnvironmentSpecularScale = L.EnvironmentSpecularScale;
        LowDetailBackup.ClockTime                = L.ClockTime;
        L.GlobalShadows            = false;
        L.Brightness               = 3;
        L.FogEnd                   = 999999;
        L.FogStart                 = 999999;
        L.EnvironmentDiffuseScale  = 0;
        L.EnvironmentSpecularScale = 0;
        L.ClockTime                = 14;
        -- Physically remove Sky, Atmosphere, all post-effects
        for _, child in L:GetChildren() do
            if child:IsA("PostEffect") or child:IsA("Sky") or child:IsA("Atmosphere") then
                LowDetailBackup["light_child_"..child.Name] = {inst=child, parent=child.Parent};
                child.Parent = nil;
            end;
        end;
    end);

    -- Terrain
    pcall(function()
        local T = workspace:FindFirstChildOfClass("Terrain");
        if not T then return; end;
        LowDetailBackup.WaterWaveSize    = T.WaterWaveSize;
        LowDetailBackup.WaterWaveSpeed   = T.WaterWaveSpeed;
        LowDetailBackup.WaterReflectance = T.WaterReflectance;
        LowDetailBackup.WaterTransparency= T.WaterTransparency;
        LowDetailBackup.Decoration       = T.Decoration;
        T.WaterWaveSize     = 0;
        T.WaterWaveSpeed    = 0;
        T.WaterReflectance  = 0;
        T.WaterTransparency = 1;
        T.Decoration        = false;
    end);

    -- Render quality floor
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01;
    end);

    -- Nuclear workspace strip:
    -- Flat gray parts, no textures, no sounds, no effects, no surface guis
    local function NukeObject(obj)
        pcall(function()
            local t = obj.ClassName;
            if t == "ParticleEmitter" or t == "Trail" or t == "Smoke"
            or t == "Fire" or t == "Sparkles" or t == "SelectionBox"
            or t == "SelectionSphere" or t == "BillboardGui"
            or t == "SurfaceGui" or t == "SurfaceAppearance" then
                obj.Parent = nil;
            elseif t == "Decal" or t == "Texture" then
                obj.Transparency = 1;
            elseif t == "SpecialMesh" or t == "FileMesh" then
                obj.TextureId = "";
            elseif t == "Sound" then
                obj.Volume  = 0;
                obj.Playing = false;
            elseif obj:IsA("BasePart") then
                obj.Material    = Enum.Material.SmoothPlastic;
                obj.Reflectance = 0;
                obj.CastShadow  = false;
            end;
        end);
    end;

    for _, obj in workspace:GetDescendants() do NukeObject(obj); end;
    workspace.DescendantAdded:Connect(function(obj)
        if LowDetailActive then task.defer(NukeObject, obj); end;
    end);
end;

local function RemoveLowDetail()
    if not LowDetailActive then return; end;
    LowDetailActive = false;

    pcall(function()
        local L = game:GetService("Lighting");
        if LowDetailBackup.GlobalShadows ~= nil then
            L.GlobalShadows = LowDetailBackup.GlobalShadows;
        end;
        if LowDetailBackup.Brightness then L.Brightness = LowDetailBackup.Brightness; end;
        if LowDetailBackup.FogEnd     then L.FogEnd     = LowDetailBackup.FogEnd;     end;
        if LowDetailBackup.EnvironmentDiffuseScale then
            L.EnvironmentDiffuseScale  = LowDetailBackup.EnvironmentDiffuseScale;
            L.EnvironmentSpecularScale = LowDetailBackup.EnvironmentSpecularScale;
        end;
        for _, fx in L:GetChildren() do
            if fx:IsA("PostEffect") then
                local key = "fx_" .. fx.Name .. "_enabled";
                if LowDetailBackup[key] ~= nil then fx.Enabled = LowDetailBackup[key]; end;
            end;
        end;
        local atmo = L:FindFirstChildOfClass("Atmosphere");
        if atmo and LowDetailBackup.AtmoDensity then
            atmo.Density = LowDetailBackup.AtmoDensity;
        end;
    end);

    pcall(function()
        local T = workspace:FindFirstChildOfClass("Terrain");
        if not T then return; end;
        if LowDetailBackup.WaterWaveSize  then T.WaterWaveSize   = LowDetailBackup.WaterWaveSize;  end;
        if LowDetailBackup.WaterWaveSpeed then T.WaterWaveSpeed  = LowDetailBackup.WaterWaveSpeed; end;
        if LowDetailBackup.WaterReflectance then T.WaterReflectance = LowDetailBackup.WaterReflectance; end;
        if LowDetailBackup.WaterTransparency then T.WaterTransparency = LowDetailBackup.WaterTransparency; end;
    end);

    -- Note: particles/decals/sounds can't easily be restored without
    -- full table backup; rejoin or disable/enable recommended.
    print("[UE] Low Detail OFF — rejoin recommended to restore particles/decals");
end;

