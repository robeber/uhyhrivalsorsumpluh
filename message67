OnHit=function(p) TRACKER.Hits=TRACKER.Hits+1; TRACKER.Shots=TRACKER.Shots+1; _roh(p); end;
OnMiss=function(p) TRACKER.Shots=TRACKER.Shots+1; _rom(p); end;

