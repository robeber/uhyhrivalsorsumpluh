-- -----------------------------------------------------------------
--  [10] VOID SPAM  (desync + random teleport fusion)
--
--  HOW IT WORKS:
--    Heartbeat  > teleports HRP server-side to a random huge coord
--                 AND randomises velocity/angular velocity
--    RenderStep > snaps everything back client-side at First priority
--                 so locally you never move
--
--  This means the SERVER sees you at a random position every frame
--  while the CLIENT (you) sees yourself standing still. Classic
--  desync void - unhittable, looks normal on your end.
--
--  DEVICE DETECTION:
--    Mobile  > draggable void button (lower-left area)
--    PC      > "Press G to toggle Void" hint at bottom-center
--              G key toggles it
-- -----------------------------------------------------------------

-- -- Config -------------------------------------------------------
local VOID_CFG = {
    Enabled      = false,
    -- How far to scatter server position (stay within int32 safe range)
    ScatterMin   = 9999,
    ScatterMax   = 2000000000,
    -- Dead zone in the middle so you don't accidentally land near origin
    DeadZoneMin  = 500000000,
};

-- -- betterRandom: avoids dead zone around 0 ----------------------
local function BetterRandom(mi, ma, dmi, dma)
    local val = math.random(mi, ma);
    local tries = 0;
    repeat
        val   = math.random(mi, ma);
        tries += 1;
    until val < dmi or val > dma or tries > 20;
    return val;
end;

local function RandomScatter()
    local mn  = VOID_CFG.ScatterMin;
    local mx  = VOID_CFG.ScatterMax;
    local dmn = VOID_CFG.DeadZoneMin;
    local function Axis()
        return BetterRandom(mn, mx, dmn, mx) * (math.random(0,1) == 0 and -1 or 1);
    end;
    return Axis(), Axis(), Axis();
end;

-- -- State ---------------------------------------------------------
local VS_hrp      = nil;
local VS_clientCF = nil;
local VS_clientLV = nil;
local VS_clientAV = nil;
local VS_heartbeat = nil;
local VS_renderstep = nil;

local function VS_Start()
    if VS_heartbeat then return; end;

    -- Heartbeat: desync server position every frame
    VS_heartbeat = RunService.Heartbeat:Connect(function()
        if not VOID_CFG.Enabled then return; end;
        pcall(function()
            VS_hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart");
            if not VS_hrp then return; end;

            -- Save real client state before scatter
            VS_clientCF = VS_hrp.CFrame;
            VS_clientLV = VS_hrp.AssemblyLinearVelocity;
            VS_clientAV = VS_hrp.AssemblyAngularVelocity;

            -- Scatter server-side
            local sx, sy, sz = RandomScatter();
            VS_hrp.CFrame = CFrame.new(sx, sy, sz)
                          * CFrame.Angles(math.rad(math.pi), math.rad(math.pi), math.rad(math.pi));
            VS_hrp.AssemblyLinearVelocity = Vector3.new(
                BetterRandom(10000, 2000000000, 500000000, 2000000000) * (math.random(0,1)==0 and -1 or 1),
                BetterRandom(10000, 2000000000, 500000000, 2000000000) * (math.random(0,1)==0 and -1 or 1),
                BetterRandom(10000, 2000000000, 500000000, 2000000000) * (math.random(0,1)==0 and -1 or 1)
            );
            VS_hrp.AssemblyAngularVelocity = Vector3.new(
                BetterRandom(10000, 2000000000, 500000000, 2000000000) * (math.random(0,1)==0 and -1 or 1),
                BetterRandom(10000, 2000000000, 500000000, 2000000000) * (math.random(0,1)==0 and -1 or 1),
                BetterRandom(10000, 2000000000, 500000000, 2000000000) * (math.random(0,1)==0 and -1 or 1)
            );
        end);
    end);

    -- RenderStep: snap back client-side at highest priority BEFORE render
    VS_renderstep = RunService:BindToRenderStep("UEVoidSync",
        Enum.RenderPriority.First.Value,
        function()
            if not VOID_CFG.Enabled then return; end;
            if VS_hrp and VS_clientCF then
                pcall(function()
                    VS_hrp.CFrame                  = VS_clientCF;
                    VS_hrp.AssemblyLinearVelocity  = VS_clientLV;
                    VS_hrp.AssemblyAngularVelocity = VS_clientAV;
                end);
            end;
        end
    );
end;

local function VS_Stop()
    if VS_heartbeat    then VS_heartbeat:Disconnect();   VS_heartbeat    = nil; end;
    if VS_renderstep   then RunService:UnbindFromRenderStep("UEVoidSync"); VS_renderstep = nil; end;
    VS_hrp = nil;
end;

local function VS_Toggle()
    VOID_CFG.Enabled = not VOID_CFG.Enabled;
    if VOID_CFG.Enabled then
        VS_Start();
    else
        VS_Stop();
    end;
    return VOID_CFG.Enabled;
end;

