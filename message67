local function ResizePanel()
    local h   = ListLayout.AbsoluteContentSize.Y + 26 + 6;
    local cap = math.min(h, 340);
    local px  = Panel.Position.X.Offset;
    Panel.Size     = UDim2.new(0,198,0,cap);
    Panel.Position = UDim2.new(0,px,1,-(cap+8));
end;
