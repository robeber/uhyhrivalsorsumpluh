-- ─────────────────────────────────────────────────────────────────
--  EXPERIMENTAL: PACKET BURST FIRE
--  Fires Activate() N extra times in the same frame on each shot.
--  Can multi-hit during high-lag frames. OFF by default.
-- ─────────────────────────────────────────────────────────────────
local PacketBurst      = false;
local PacketBurstCount = 3;
local PacketBurstBusy  = false;

local function RunPacketBurst()
    if not PacketBurst or PacketBurstBusy then return; end;
    local char = GetChar();
    if not char then return; end;
    local tool = char:FindFirstChildOfClass("Tool");
    if not tool or not tool.Name:lower():find("slingshot") then return; end;
    PacketBurstBusy = true;
    task.spawn(function()
        for _ = 1, PacketBurstCount do
            pcall(function() tool:Activate(); end);
        end;
        PacketBurstBusy = false;
    end);
end;

local function HookBurst(char)
    if not char then return; end;
    char.ChildAdded:Connect(function(c)
        if c:IsA("Tool") and c.Name:lower():find("slingshot") then
            c.Activated:Connect(RunPacketBurst);
        end;
    end);
    local t = char:FindFirstChildOfClass("Tool");
    if t and t.Name:lower():find("slingshot") then t.Activated:Connect(RunPacketBurst); end;
end;
HookBurst(GetChar());
