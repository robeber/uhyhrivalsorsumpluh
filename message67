--  Can multi-hit during high-lag frames. OFF by default.
-- -----------------------------------------------------------------
local PacketBurst      = false;
local PacketBurstCount = 3;
local PacketBurstBusy  = false;

local function RunPacketBurst()
    if not PacketBurst or PacketBurstBusy then return; end;
    local char = GetChar();
    if not char then return; end;
    local tool = char:FindFirstChildOfClass("Tool");
    if not tool or not tool.Name:lower():find("slingshot") then return; end;
    PacketBurstBusy = true;
    task.spawn(function()
        for _ = 1, PacketBurstCount do
            pcall(function() tool:Activate(); end);
        end;
        PacketBurstBusy = false;
    end);
end;

