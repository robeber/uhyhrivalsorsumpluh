local VS_hb  = nil; local VS_rs = nil;

local function BRand(mi, ma, dmi, dma)
    local v = math.random(mi, ma); local t = 0;
    repeat v = math.random(mi, ma); t = t + 1; until v < dmi or v > dma or t > 20;
    return v;
end;

local function VS_Start()
    if VS_hb then return; end;
    VS_hb = RunService.Heartbeat:Connect(function()
        if not VOID_CFG.Enabled then return; end;
        pcall(function()
            VS_hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart");
            if not VS_hrp then return; end;
            VS_cf = VS_hrp.CFrame;
            VS_lv = VS_hrp.AssemblyLinearVelocity;
            VS_av = VS_hrp.AssemblyAngularVelocity;
            local function A() return BRand(9999,2000000000,500000000,2000000000)*(math.random(0,1)==0 and -1 or 1); end;
            VS_hrp.CFrame = CFrame.new(A(),A(),A()) * CFrame.Angles(math.rad(math.pi),math.rad(math.pi),math.rad(math.pi));
            VS_hrp.AssemblyLinearVelocity  = Vector3.new(A(),A(),A());
            VS_hrp.AssemblyAngularVelocity = Vector3.new(A(),A(),A());
        end);
    end);
    VS_rs = RunService:BindToRenderStep("UEVoidSync", Enum.RenderPriority.First.Value, function()
        if not VOID_CFG.Enabled then return; end;
        if VS_hrp and VS_cf then
            pcall(function()
                VS_hrp.CFrame                  = VS_cf;
                VS_hrp.AssemblyLinearVelocity  = VS_lv;
                VS_hrp.AssemblyAngularVelocity = VS_av;
            end);
        end;
    end);
end;

local function VS_Stop()
    if VS_hb then VS_hb:Disconnect(); VS_hb = nil; end;
    pcall(function() RunService:UnbindFromRenderStep("UEVoidSync"); end);
    VS_hrp = nil;
end;

local function VS_Toggle()
    VOID_CFG.Enabled = not VOID_CFG.Enabled;
    if VOID_CFG.Enabled then VS_Start(); else VS_Stop(); end;
    return VOID_CFG.Enabled;
end;

LocalPlayer.CharacterAdded:Connect(function()
    VS_hrp = nil; VS_cf = nil; VS_lv = nil; VS_av = nil;
end);

