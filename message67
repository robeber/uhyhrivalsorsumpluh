    for player, rd in pairs(DB) do
        if not IsAlive(player) then continue; end;
        local their = player.Character and player.Character:FindFirstChild("HumanoidRootPart");
        if not their then continue; end;
        local dist = (myRoot.Position - their.Position).Magnitude;
        local tof  = dist / SLING_SPEED;
        rd.rOptimalPred = tof + PING_ESTIMATE;
