-- -----------------------------------------------------------------
--  LOW DETAIL MODE
--
--  Strips as much visual noise as possible to squeeze FPS on
--  mobile / low-end devices. Off by default.
--  Affects: textures, meshes, particles, decals, post-processing,
--           shadows, terrain quality, water rendering, sounds.
-- -----------------------------------------------------------------

local LowDetailActive = false;
local LowDetailBackup = {}; -- store originals for restore

local function ApplyLowDetail()
    if LowDetailActive then return; end;
    LowDetailActive = true;

    -- Lighting: remove Sky, Atmosphere, all PostEffects, zero shadows
    pcall(function()
        local L = game:GetService("Lighting");
        LowDetailBackup.GlobalShadows            = L.GlobalShadows;
        LowDetailBackup.Brightness               = L.Brightness;
        LowDetailBackup.FogEnd                   = L.FogEnd;
        LowDetailBackup.FogStart                 = L.FogStart;
        LowDetailBackup.EnvironmentDiffuseScale  = L.EnvironmentDiffuseScale;
        LowDetailBackup.EnvironmentSpecularScale = L.EnvironmentSpecularScale;
        LowDetailBackup.ClockTime                = L.ClockTime;
        L.GlobalShadows            = false;
        L.Brightness               = 3;
        L.FogEnd                   = 999999;
        L.FogStart                 = 999999;
        L.EnvironmentDiffuseScale  = 0;
        L.EnvironmentSpecularScale = 0;
        L.ClockTime                = 14;
        -- Physically remove Sky, Atmosphere, all post-effects
        for _, child in L:GetChildren() do
            if child:IsA("PostEffect") or child:IsA("Sky") or child:IsA("Atmosphere") then
                LowDetailBackup["light_child_"..child.Name] = {inst=child, parent=child.Parent};
                child.Parent = nil;
            end;
        end;
    end);

    -- Terrain
    pcall(function()
        local T = workspace:FindFirstChildOfClass("Terrain");
        if not T then return; end;
        LowDetailBackup.WaterWaveSize    = T.WaterWaveSize;
        LowDetailBackup.WaterWaveSpeed   = T.WaterWaveSpeed;
        LowDetailBackup.WaterReflectance = T.WaterReflectance;
        LowDetailBackup.WaterTransparency= T.WaterTransparency;
        LowDetailBackup.Decoration       = T.Decoration;
        T.WaterWaveSize     = 0;
        T.WaterWaveSpeed    = 0;
        T.WaterReflectance  = 0;
        T.WaterTransparency = 1;
        T.Decoration        = false;
    end);

    -- Render quality floor
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01;
    end);

    -- Nuclear workspace strip:
    -- Flat gray parts, no textures, no sounds, no effects, no surface guis
    local function NukeObject(obj)
        pcall(function()
            local t = obj.ClassName;
            if t == "ParticleEmitter" or t == "Trail" or t == "Smoke"
            or t == "Fire" or t == "Sparkles" or t == "SelectionBox"
            or t == "SelectionSphere" or t == "BillboardGui"
            or t == "SurfaceGui" or t == "SurfaceAppearance" then
                obj.Parent = nil;
            elseif t == "Decal" or t == "Texture" then
                obj.Transparency = 1;
            elseif t == "SpecialMesh" or t == "FileMesh" then
                obj.TextureId = "";
            elseif t == "Sound" then
                obj.Volume  = 0;
                obj.Playing = false;
            elseif obj:IsA("BasePart") then
                obj.Material    = Enum.Material.SmoothPlastic;
                obj.Reflectance = 0;
                obj.CastShadow  = false;
            end;
        end);
    end;

    for _, obj in workspace:GetDescendants() do NukeObject(obj); end;
    workspace.DescendantAdded:Connect(function(obj)
        if LowDetailActive then task.defer(NukeObject, obj); end;
    end);
end;

local function RemoveLowDetail()
    if not LowDetailActive then return; end;
    LowDetailActive = false;

    pcall(function()
        local L = game:GetService("Lighting");
        if LowDetailBackup.GlobalShadows ~= nil then
            L.GlobalShadows = LowDetailBackup.GlobalShadows;
        end;
        if LowDetailBackup.Brightness then L.Brightness = LowDetailBackup.Brightness; end;
        if LowDetailBackup.FogEnd     then L.FogEnd     = LowDetailBackup.FogEnd;     end;
        if LowDetailBackup.EnvironmentDiffuseScale then
            L.EnvironmentDiffuseScale  = LowDetailBackup.EnvironmentDiffuseScale;
            L.EnvironmentSpecularScale = LowDetailBackup.EnvironmentSpecularScale;
        end;
        for _, fx in L:GetChildren() do
            if fx:IsA("PostEffect") then
                local key = "fx_" .. fx.Name .. "_enabled";
                if LowDetailBackup[key] ~= nil then fx.Enabled = LowDetailBackup[key]; end;
            end;
        end;
        local atmo = L:FindFirstChildOfClass("Atmosphere");
        if atmo and LowDetailBackup.AtmoDensity then
            atmo.Density = LowDetailBackup.AtmoDensity;
        end;
    end);

    pcall(function()
        local T = workspace:FindFirstChildOfClass("Terrain");
        if not T then return; end;
        if LowDetailBackup.WaterWaveSize  then T.WaterWaveSize   = LowDetailBackup.WaterWaveSize;  end;
        if LowDetailBackup.WaterWaveSpeed then T.WaterWaveSpeed  = LowDetailBackup.WaterWaveSpeed; end;
        if LowDetailBackup.WaterReflectance then T.WaterReflectance = LowDetailBackup.WaterReflectance; end;
