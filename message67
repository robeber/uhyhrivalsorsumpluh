local LowDetailActive = false;
local LDBackup = {};

local function ApplyLowDetail()
    if LowDetailActive then return; end;
    LowDetailActive = true;
    pcall(function()
        local L = game:GetService("Lighting");
        LDBackup.GlobalShadows = L.GlobalShadows;
        LDBackup.Brightness    = L.Brightness;
        LDBackup.ClockTime     = L.ClockTime;
        L.GlobalShadows = false;
        L.Brightness    = 3;
        L.ClockTime     = 14;
        for _, child in ipairs(L:GetChildren()) do
            if child:IsA("PostEffect") or child:IsA("Sky") or child:IsA("Atmosphere") then
                LDBackup["lc_"..child.Name] = {inst=child, parent=child.Parent};
                child.Parent = nil;
            end;
        end;
    end);
    pcall(function()
        local T = workspace:FindFirstChildOfClass("Terrain");
        if not T then return; end;
        LDBackup.WaterWave    = T.WaterWaveSize;
        LDBackup.WaterSpeed   = T.WaterWaveSpeed;
        LDBackup.WaterReflect = T.WaterReflectance;
        LDBackup.WaterTrans   = T.WaterTransparency;
        LDBackup.Decoration   = T.Decoration;
        T.WaterWaveSize     = 0;
        T.WaterWaveSpeed    = 0;
        T.WaterReflectance  = 0;
        T.WaterTransparency = 1;
        T.Decoration        = false;
    end);
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01;
    end);
    local function Nuke(obj)
        pcall(function()
            local t = obj.ClassName;
            if t == "ParticleEmitter" or t == "Trail" or t == "Smoke"
            or t == "Fire" or t == "Sparkles" or t == "SurfaceAppearance"
            or t == "BillboardGui" or t == "SurfaceGui" then
                obj.Parent = nil;
            elseif t == "Decal" or t == "Texture" then
                obj.Transparency = 1;
            elseif t == "SpecialMesh" or t == "FileMesh" then
                obj.TextureId = "";
            elseif t == "Sound" then
                obj.Volume = 0;
            elseif obj:IsA("BasePart") then
                obj.Material    = Enum.Material.SmoothPlastic;
                obj.Reflectance = 0;
                obj.CastShadow  = false;
            end;
        end);
    end;
    for _, obj in ipairs(workspace:GetDescendants()) do Nuke(obj); end;
    workspace.DescendantAdded:Connect(function(obj)
        if LowDetailActive then task.defer(Nuke, obj); end;
    end);
end;

local function RemoveLowDetail()
    if not LowDetailActive then return; end;
    LowDetailActive = false;
    pcall(function()
        local L = game:GetService("Lighting");
        if LDBackup.GlobalShadows ~= nil then L.GlobalShadows = LDBackup.GlobalShadows; end;
        if LDBackup.Brightness    then L.Brightness = LDBackup.Brightness; end;
        if LDBackup.ClockTime     then L.ClockTime  = LDBackup.ClockTime;  end;
        for k, v in pairs(LDBackup) do
            if k:sub(1,3) == "lc_" and type(v) == "table" and v.inst then
                v.inst.Parent = v.parent;
            end;
        end;
    end);
    pcall(function()
        local T = workspace:FindFirstChildOfClass("Terrain");
        if not T then return; end;
        if LDBackup.WaterWave    then T.WaterWaveSize    = LDBackup.WaterWave;    end;
        if LDBackup.WaterSpeed   then T.WaterWaveSpeed   = LDBackup.WaterSpeed;   end;
        if LDBackup.WaterReflect then T.WaterReflectance = LDBackup.WaterReflect; end;
        if LDBackup.WaterTrans   then T.WaterTransparency= LDBackup.WaterTrans;   end;
        if LDBackup.Decoration ~= nil then T.Decoration  = LDBackup.Decoration;   end;
    end);
end;

